// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                 String           @id @default(cuid())
  clerkId            String           @unique
  email              String           @unique
  firstName          String?
  lastName           String?
  imageUrl           String?
  bio                String?          @db.Text
  location           String?
  linkedinUrl        String?
  targetRole         String?
  targetIndustry     String?
  experienceLevel    ExperienceLevel?
  careerGoals        String?          @db.Text
  onboardingComplete Boolean          @default(false)
  theme              Theme            @default(SYSTEM)
  preferredLanguage  String           @default("en")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  phone              String?
  country            String?
  timezone           String?
  githubUrl          String?
  portfolioUrl       String?
  leetcodeUrl        String?
  hackerrankUrl      String?
  codeforcesUrl      String?
  twitterUrl         String?
  mediumUrl          String?
  behanceUrl         String?
  dribbbleUrl        String?
  dob                String?
  preferredContact   String?
  dreamCompany       String?
  employmentType     String?
  expectedSalary     String?
  prefWorkLocation   String?
  openToRelocation   Boolean          @default(false)
  yearsOfExperience  Float?
  noticePeriod       String?
  currentStatus      String?
  skills             Json?
  aiPreferences      Json?
  notificationSettings Json?
  privacySettings    Json?
  careerGoalsTimeline Json?
  securitySettings     Json?
  connectedAccounts    Json?
  resumePreferences    Json?
  jobPreferences       Json?
  accessibilitySettings Json?
  appearanceSettings   Json?

  resumes            Resume[]
  jobDescriptions    JobDescription[]
  jobMatches         JobMatch[]
  interviewSessions  InterviewSession[]
  reviews            Review[]
  education          Education[]
  experience         WorkExperience[]
  projects           Project[]
  certifications     Certification[]
  languages          LanguageProficiency[]
  achievements       Achievement[]
  voiceInterviewSessions VoiceInterviewSession[]
  voiceInterviewSettings VoiceInterviewSettings?

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  EXECUTIVE
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

// ─────────────────────────────────────────────
// RESUME
// ─────────────────────────────────────────────

model Resume {
  id           String          @id @default(cuid())
  userId       String
  fileName     String
  fileUrl      String
  fileType     FileType
  fileSize     Int
  status       ResumeStatus    @default(UPLOADED)
  version      Int             @default(1)
  parsedData   Json?
  rawText      String?         @db.Text
  parsingError String?         @db.Text
  isPrimary    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis   ResumeAnalysis?
  jobMatches JobMatch[]

  @@index([userId])
  @@index([userId, isPrimary])
  @@index([status])
  @@map("resumes")
}

enum FileType {
  PDF
  DOCX
}

enum ResumeStatus {
  UPLOADED
  PARSING
  PARSED
  ANALYZING
  ANALYZED
  ERROR
}

// ─────────────────────────────────────────────
// RESUME ANALYSIS (1:1 with Resume)
// ─────────────────────────────────────────────

model ResumeAnalysis {
  id              String   @id @default(cuid())
  resumeId        String   @unique
  overallScore    Int
  atsScore        Int
  skillsScore     Int
  experienceScore Int
  educationScore  Int
  projectsScore   Int
  grammarScore    Int
  scoreBreakdown  Json?
  suggestions     Json?
  keywords        Json?
  summary         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("resume_analyses")
}

// ─────────────────────────────────────────────
// JOB DESCRIPTION
// ─────────────────────────────────────────────

model JobDescription {
  id        String     @id @default(cuid())
  userId    String
  title     String?
  company   String?
  content   String     @db.Text
  source    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatches JobMatch[]

  @@index([userId])
  @@map("job_descriptions")
}

// ─────────────────────────────────────────────
// JOB MATCH (references both Resume and JobDescription)
// ─────────────────────────────────────────────

model JobMatch {
  id               String   @id @default(cuid())
  userId           String
  resumeId         String
  jobDescriptionId String
  matchScore       Int
  matchedSkills    Json
  missingSkills    Json
  matchedKeywords  Json
  missingKeywords  Json
  suggestions      Json
  analysis         Json?
  summary          String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
  @@index([jobDescriptionId])
  @@map("job_matches")
}

// ─────────────────────────────────────────────
// INTERVIEW SESSION
// ─────────────────────────────────────────────

model InterviewSession {
  id             String              @id @default(cuid())
  userId         String
  title          String
  role           String
  difficulty     Difficulty
  questionTypes  Json
  status         InterviewStatus     @default(ACTIVE)
  overallScore   Int?
  categoryScores Json?
  evaluation     Json?
  feedback       String?             @db.Text
  duration       Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  completedAt    DateTime?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      InterviewQuestion[]

  @@index([userId])
  @@index([userId, status])
  @@map("interview_sessions")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// ─────────────────────────────────────────────
// INTERVIEW QUESTION
// ─────────────────────────────────────────────

model InterviewQuestion {
  id           String           @id @default(cuid())
  sessionId    String
  content      String           @db.Text
  questionType QuestionType
  order        Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  session      InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer       InterviewAnswer?

  @@index([sessionId])
  @@index([sessionId, order])
  @@map("interview_questions")
}

enum QuestionType {
  BEHAVIORAL
  TECHNICAL
  SITUATIONAL
}

// ─────────────────────────────────────────────
// INTERVIEW ANSWER (1:1 with InterviewQuestion)
// ─────────────────────────────────────────────

model InterviewAnswer {
  id             String            @id @default(cuid())
  questionId     String            @unique
  content        String            @db.Text
  score          Int?
  feedback       String?           @db.Text
  improvedAnswer String?           @db.Text
  analysis       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  question       InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("interview_answers")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  title     String
  review    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// PORTFOLIO EDUCATION
// ─────────────────────────────────────────────

model Education {
  id           String   @id @default(cuid())
  userId       String
  college      String
  degree       String
  branch       String?
  cgpa         String?
  startYear    String
  endYear      String
  achievements String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("education")
}

// ─────────────────────────────────────────────
// PORTFOLIO EXPERIENCE
// ─────────────────────────────────────────────

model WorkExperience {
  id               String   @id @default(cuid())
  userId       String
  company          String
  role             String
  employmentType   String?
  startDate        String
  endDate          String?
  currentJob       Boolean  @default(false)
  responsibilities String?  @db.Text
  achievements     String?  @db.Text
  technologies     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("work_experiences")
}

// ─────────────────────────────────────────────
// PORTFOLIO PROJECTS
// ─────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String   @db.Text
  techStack    Json?
  githubLink   String?
  liveDemo     String?
  role         String?
  duration     String?
  achievements String?  @db.Text
  highlighted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("projects")
}

// ─────────────────────────────────────────────
// PORTFOLIO CERTIFICATIONS
// ─────────────────────────────────────────────

model Certification {
  id            String   @id @default(cuid())
  userId        String
  name          String
  issuer        String
  issueDate     String
  credentialUrl String?
  expiry        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("certifications")
}

// ─────────────────────────────────────────────
// PORTFOLIO LANGUAGES
// ─────────────────────────────────────────────

model LanguageProficiency {
  id          String   @id @default(cuid())
  userId      String
  language    String
  proficiency String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("language_proficiencies")
}

// ─────────────────────────────────────────────
// PORTFOLIO ACHIEVEMENTS
// ─────────────────────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    String
  description String?  @db.Text
  date        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("achievements")
}

// ─────────────────────────────────────────────
// VOICE MOCK INTERVIEW MODULE
// ─────────────────────────────────────────────

model VoiceInterviewSession {
  id             String                   @id @default(cuid())
  userId         String
  title          String
  role           String
  difficulty     Difficulty
  interviewType  String
  duration       Int                      @default(15)
  language       String                   @default("en")
  voice          String                   @default("native")
  status         InterviewStatus          @default(ACTIVE)
  overallScore   Int?
  feedback       String?                  @db.Text
  roadmap        Json?
  videoEnabled   Boolean                  @default(false)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  completedAt    DateTime?

  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      VoiceInterviewQuestion[]
  analytics      VoiceInterviewAnalytics?
  transcripts    VoiceTranscript[]

  @@index([userId])
  @@index([status])
  @@map("voice_interview_sessions")
}

model VoiceInterviewQuestion {
  id           String                 @id @default(cuid())
  sessionId    String
  content      String                 @db.Text
  order        Int
  createdAt    DateTime               @default(now())

  session      VoiceInterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer       VoiceInterviewAnswer?

  @@index([sessionId])
  @@index([sessionId, order])
  @@map("voice_interview_questions")
}

model VoiceInterviewAnswer {
  id                  String                 @id @default(cuid())
  questionId          String                 @unique
  userResponse        String                 @db.Text
  score               Int?
  technicalAccuracy   Int?
  communication       Int?
  grammar             Int?
  vocabulary          Int?
  confidence          Int?
  completeness        Int?
  fluency             Int?
  professionalism     Int?
  strengths           Json?
  weaknesses          Json?
  improvedAnswer      String?                @db.Text
  createdAt           DateTime               @default(now())

  question            VoiceInterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("voice_interview_answers")
}

model VoiceTranscript {
  id           String                 @id @default(cuid())
  sessionId    String
  speaker      String
  text         String                 @db.Text
  timestamp    DateTime               @default(now())

  session      VoiceInterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("voice_transcripts")
}

model VoiceInterviewAnalytics {
  id                        String                 @id @default(cuid())
  sessionId                 String                 @unique
  
  speakingSpeed             Float?
  wordsPerMinute            Float?
  avgPause                  Float?
  longestPause              Float?
  responseTime              Float?
  thinkingTime              Float?
  fillerWords               Json?
  grammarScore              Int?
  vocabularyScore           Int?
  communicationScore        Int?
  technicalScore            Int?
  confidenceScore           Int?
  speechAccuracy            Float?
  fluency                   Float?

  eyeContactScore           Int?
  postureScore              Int?
  attentionScore            Int?
  lightingScore             Int?
  faceCenteringScore        Int?
  cameraPresenceScore       Int?
  engagementScore           Int?
  faceDetectionPercentage   Float?
  lookingAwayFrequency      Float?
  smileCount                Int?
  shoulderAlignmentScore    Int?
  bodyStabilityScore        Int?
  screenEngagementScore     Int?
  cameraDistanceScore       Int?
  blinkFrequency            Float?

  session                   VoiceInterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("voice_interview_analytics")
}

model VoiceInterviewSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  preferredVoice       String   @default("native")
  speakingSpeed        Float    @default(1.0)
  pitch                Float    @default(1.0)
  volume               Float    @default(1.0)
  difficulty           String   @default("MEDIUM")
  duration             Int      @default(15)
  language             String   @default("en")
  autoSave             Boolean  @default(true)
  autoDownloadReport   Boolean  @default(false)
  microphoneDevice     String?
  noiseSuppression     Boolean  @default(true)

  enableCamera         Boolean  @default(false)
  defaultCameraDevice  String?
  mirrorCamera         Boolean  @default(true)
  videoResolution      String   @default("720p")
  frameRate            Int      @default(30)
  showLivePreview      Boolean  @default(true)
  enableLiveCoaching   Boolean  @default(true)
  enableVideoAnalytics Boolean  @default(true)

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_interview_settings")
}
